# Runtime
NODE_ENV=production
PORT=3004
BASE_URL=https://api.example.com
LOG_LEVEL=info

# CORS (comma separated origins)
CORS_ORIGINS=https://app.example.com,https://www.app.example.com

# PostgreSQL
DB_HOST=database-host.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=checklist-delegation
PG_SSL=true
PGSSLMODE=require
DB_CONNECT_RETRIES=3

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30d

# MAYTAPI / WhatsApp (optional)
MAYTAPI_PRODUCT_ID=
MAYTAPI_PHONE_ID=
MAYTAPI_TOKEN=

WHATSAPP_GROUP_IDS_SMS_REGISTER=
WHATSAPP_GROUP_IDS_RECOILER=
WHATSAPP_GROUP_IDS_HOT_COIL=
WHATSAPP_GROUP_IDS_PIPE_MILL=
WHATSAPP_GROUP_IDS_QC_LAB=
WHATSAPP_GROUP_IDS_TUNDISH=
WHATSAPP_GROUP_IDS_LADDLE=
